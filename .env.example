# Chain Monitor — Environment Variables
# Agent-native only. No LLM. No Telegram. The running agent reads saved prompts.

# Data Source APIs (optional)
# COINGECKO_API_KEY=*** YOUTUBE_API_KEY=*** GITHUB_TOKEN=***

# Runtime settings
LOG_LEVEL=INFO
DATA_RETENTION_DAYS=90

# Twitter settings
TWITTER_LOOKBACK_HOURS=24
TWITTER_MAX_WORKERS=15
TWITTER_NUM_BATCHES=15
TWITTER_THREAD_DEPTH=0
