# Chain Monitor — Environment Variables
# Copy this to .env and fill in your values

CRYPTORANK_API_KEY=your_c...here
COINGECKO_API_KEY=your_c...here
YOUTUBE_API_KEY=your_y...here
TELEGRAM_BOT_TOKEN=your_t...here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
GITHUB_TOKEN=your_g...here

# Twitter/X collector
TWITTER_LOOKBACK_HOURS=24          # Default: 24 hours (daily), set to 168 for weekly

# Optional
LOG_LEVEL=INFO
DATA_RETENTION_DAYS=180
