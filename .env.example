# Chain Monitor — Environment Variables
# Copy to .env and fill in your values

# LLM Provider: ollama, openrouter, openai, custom
LLM_PROVIDER=ollama
LLM_MODEL=minimax-m2.7:cloud
LLM_FALLBACK_MODEL=gemma4:31b-cloud
OLLAMA_HOST=http://localhost:11434

# Digest generation
LLM_DIGEST_ENABLED=true
LLM_DIGEST_MODEL=glm-5.1:cloud
LLM_DIGEST_TEMPERATURE=0.4
LLM_DIGEST_MAX_TOKENS=2048
LLM_DIGEST_TIMEOUT=45

# Data Source APIs (optional)
# OPENROUTER_API_KEY=
# CRYPTORANK_API_KEY=
# COINGECKO_API_KEY=
# YOUTUBE_API_KEY=
# GITHUB_TOKEN=

# Telegram delivery
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Runtime settings
LOG_LEVEL=INFO
DATA_RETENTION_DAYS=90

# Twitter settings
TWITTER_LOOKBACK_HOURS=24
TWITTER_MAX_WORKERS=15
TWITTER_NUM_BATCHES=10
TWITTER_THREAD_DEPTH=0

# Parallelization
LLM_MAX_CONCURRENT_CHAINS=5
