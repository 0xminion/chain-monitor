# Chain Monitor — Environment Variables
# Copy this to .env and fill in your values

CRYPTORANK_API_KEY=your_c...here
COINGECKO_API_KEY=your_c...here
YOUTUBE_API_KEY=your_y...here
TELEGRAM_BOT_TOKEN=your_t...here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
GITHUB_TOKEN=your_g...here

# Twitter/X collector
TWITTER_LOOKBACK_HOURS=24          # Default: 24 hours (daily), set to 168 for weekly
TWITTER_THREAD_DEPTH=0             # Thread following depth (0=disabled, 1-3=follow N levels)

# LLM — Semantic Enrichment
LLM_PROVIDER=ollama
LLM_MODEL=minimax-m2.7:cloud
LLM_FALLBACK_MODEL=gemma4:31b-cloud
LLM_TEMPERATURE=0.1
LLM_TIMEOUT=30
LLM_CACHE_TTL_HOURS=168

# LLM — Digest Generation
LLM_DIGEST_ENABLED=false           # Set to true after Round 3
LLM_DIGEST_PROVIDER=ollama
LLM_DIGEST_MODEL=glm-5.1:cloud
LLM_DIGEST_TEMPERATURE=0.4
LLM_DIGEST_MAX_TOKENS=1500
LLM_DIGEST_TIMEOUT=45

# Optional
LOG_LEVEL=INFO
DATA_RETENTION_DAYS=180
