# Chain Monitor — Environment Variables
# Copy this to .env and fill in your values
# v2.0 is fully agent-native: no LLM keys required. Just Telegram.

CRYPTORANK_API_KEY=***
COINGECKO_API_KEY=***
YOUTUBE_API_KEY=***
TELEGRAM_BOT_TOKEN=***
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
GITHUB_TOKEN=***

# Twitter/X collector
TWITTER_LOOKBACK_HOURS=24          # Default: 24 hours (daily), set to 168 for weekly
TWITTER_THREAD_DEPTH=0             # Thread following depth (0=disabled, 1-3=follow N levels)

# Optional
LOG_LEVEL=INFO
DATA_RETENTION_DAYS=180
